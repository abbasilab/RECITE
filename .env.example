# RECITE Environment Configuration
# Copy this file to .env and fill in your API keys.
# Do NOT commit .env to version control.

# Required: OpenAI API key (used for LLM calls and judge evaluation)
OPENAI_API_KEY=

# Optional: Local DB directory (default: data/dev)
# LOCAL_DB_DIR=data/dev

# Optional: Override specific DB paths
# ACCRUAL_DB_PATH=data/dev/accrual.db
# DATABASE_PATH=data/dev/benchmark.db

# Optional: UCSF institutional API (Azure-compatible endpoint)
# Only needed if you have access to a UCSF Versa deployment.
#
# ⚠️  WARNING: UCSF Versa API calls cost REAL MONEY (Azure OpenAI pricing).
# ⚠️  DO NOT run large-scale evaluations (e.g., 3K+ judge calls) without
# ⚠️  explicit approval from Russ. Use local models (Ollama/vLLM) for bulk
# ⚠️  predictions and only use Versa for judging small samples or final runs.
# ⚠️  GPT-4o judge on 3,116 samples ≈ $30-60 depending on token lengths.
#
# UCSF_API_KEY=
# UCSF_API_VER=2024-10-21
# UCSF_RESOURCE_ENDPOINT=https://your-institutional-endpoint
