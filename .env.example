# RECITE Environment Configuration
# Copy this file to .env and fill in your API keys.

# Required: OpenAI API key (used for LLM calls and judge evaluation)
OPENAI_API_KEY=

# Optional: Local DB directory (default: data/dev)
# LOCAL_DB_DIR=data/dev

# Optional: Azure OpenAI endpoint (for institutional deployments)
# UCSF_API_KEY=
# UCSF_API_VER=2024-10-21
# UCSF_RESOURCE_ENDPOINT=https://your-endpoint
